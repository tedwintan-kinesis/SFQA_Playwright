{
  "manifest_version": 3,
  "name": "SFQA Reflect",
  "version": "1.0",
  "description": "Minimal recording extension for SFQA Dashboard.",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting"
  ],
  "incognito": "spanning",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3000/*",
        "https://*.vercel.app/*",
        "https://sfqa-playwright.vercel.app/*"
      ],
      "js": [
        "content_dashboard.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content_recorder.js"
      ],
      "run_at": "document_end"
    }
  ]
}