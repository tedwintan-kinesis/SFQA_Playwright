# Copy this file to .env and fill in values

# Zephyr Scale Cloud API token (from Zephyr Scale → API Access Tokens)
ZEPHYR_TOKEN=your_zephyr_token_here

# GitHub PAT with 'repo' scope — needed for Vercel data writes back to JSON files
GITHUB_TOKEN=your_github_pat_here
GITHUB_OWNER=tedwintan-kinesis
GITHUB_REPO=SFQA_Playwright

# Dashboard basic authentication credentials
DASHBOARD_USERNAME=sfqas@abx.com
DASHBOARD_PASSWORD=your_password_here
